{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["./testing/playwright/pages/*"],
      "@utils/*": ["./testing/playwright/utils/*"],
      "@config/*": ["./testing/playwright/config/*"],
      "@fixtures/*": ["./testing/playwright/fixtures/*"]
    }
  },
  "include": ["testing/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
